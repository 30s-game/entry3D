{
  "manifest_version": 1.0,
  "name": "Entry3D",
  "version": "1.0",
  "description": "엔트리3D 만들기",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://playentry.org/project/*",
        "https://playentry.org/ws/*"
      ],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocks.js"],
      "matches": ["https://playentry.org/*"]
    }
  ]
}
